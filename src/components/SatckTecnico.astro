---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Minicards from './StackCards.astro';
---

<Layout>
  <div>
    <h2
      class="my-8 px-4 flex items-center justify-around sm:my-6 text-5xl font-titulo font-extrabold gap-x-3 dark:text-white"
    >
      Stack técnico
    </h2>
  </div>

  <div
    id="tarjetas-big"
    class="my-8 mx-5 px-4 flex flex-col items-center gap-5 sm:px-6 sm:flex sm:flex-row sm:items-stretch sm:justify-around sm:text-center lg:px-8"
  >
    <div
      id="primera"
      class="flex-col justify-center alig-center border border-white/20 rounded-2xl overflow-hidden shadow-md hover:shadow-[#1b3669] hover:-translate-y-1 transition-all duration-300 w-[300px] h-auto px-3 py-4 bg-white/20 backdrop-blur-md dark:hover:shadow-white"
    >
      <h3 class="text-2xl text-center font-semibold dark:text-white mb-[15px]">
        Lenguajes
      </h3>
      <div id="mini-tarjetas" class="">
        <Minicards title="JavaScript" description="Nivel: avanzado"
          ><img slot="icon" src="/js.png" alt="Logo de JavaScript" />
        </Minicards>

        <Minicards title="Python" description="Nivel: medio"
          ><img slot="icon" src="/py-logo.svg" alt="" />
        </Minicards>

        <Minicards title="TypeSctipt" description="Nivel: principiante"
          ><img slot="icon" src="/tp.svg" alt="" />
        </Minicards>
      </div>
    </div>

    <div
      id="segunda"
      class="flex-col justify-center alig-center border border-white/20 rounded-2xl overflow-hidden shadow-md hover:shadow-[#1b3669] hover:-translate-y-1 transition-all duration-300 w-[300px] h-auto px-3 py-4 bg-white/20 backdrop-blur-md dark:hover:shadow-white"
    >
      <h3 class="text-2xl text-center font-semibold dark:text-white mb-[15px]">
        Frameworks y Librerías
      </h3>
      <div id="mini-tarjetas" class="">
        <Minicards title="Astro" description=""
          ><img slot="icon" src="/Astro.svg" alt="" />
        </Minicards>

        <Minicards title="Vite" description=""
          ><img slot="icon" src="/vitejs.svg" alt="" />
        </Minicards>

        <Minicards title="Tailwind" description=""
          ><img slot="icon" src="/tailwind.svg" alt="" />
        </Minicards>

        <Minicards title="ReactJS" description=""
          ><img slot="icon" src="/react.svg" alt="" />
        </Minicards>
      </div>
    </div>

    <div
      id="tercera"
      class="flex-col justify-center alig-center border border-white/20 rounded-2xl overflow-hidden shadow-md hover:shadow-[#1b3669] hover:-translate-y-1 transition-all duration-300 w-[300px] h-auto px-3 py-4 bg-white/20 backdrop-blur-md dark:hover:shadow-white"
    >
      <h3 class="text-2xl text-center font-semibold dark:text-white mb-[15px]">
        Control de versiones
      </h3>
      <div id="mini-tarjetas" class="">
        <Minicards title="Git" description="Control de versiones"
          ><img slot="icon" src="/Git.svg" alt="" />
        </Minicards>
      </div>
    </div>
  </div>
</Layout>
